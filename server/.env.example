# Server
PORT=5001

# MongoDB connection string (MongoDB Atlas recommended for Render deploy)
MONGO_URI=mongodb://127.0.0.1:27017/password_reset

# URL of the deployed React client (used to build the reset link in the email)
CLIENT_URL=http://localhost:5173

# How long a reset link stays valid, in minutes
RESET_TOKEN_EXPIRY_MINUTES=15

# --- SMTP / Nodemailer ---
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="Password Reset <your_email@gmail.com>"
